@prefix iop: <https://w3id.org/iadopt/ont/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/> .

ex:issue001
    a
        iop:Variable ;
    rdfs:label
        "Issue 001" ;
    rdfs:comment
        "arrows for multiple constraints are overlapping" ;
    iop:hasObjectOfInterest
        ex:OoI ;
    iop:hasProperty
        ex:Prop ;
    iop:hasConstraint
        [ a iop:Constraint ;
             rdfs:label "Constraint I" ;
             iop:constrains ex:Prop ;
        ] ,
        [ a iop:Constraint ;
             rdfs:label "Constraint II" ;
             iop:constrains ex:Prop ;
        ] .

ex:OoI
    a
        iop:Entity ;
    rdfs:label
        "OoI" .

ex:Prop
    a
        iop:Entity ;
    rdfs:label
        "Prop" .
