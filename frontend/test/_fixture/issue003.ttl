@prefix iop: <https://w3id.org/iadopt/ont/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/> .

ex:issue003 a iop:Variable ;
    rdfs:label "Issue 003" ;
    rdfs:comment "App crashes with error 'can not read properties of undefined'" ;
    iop:hasConstraint [
      a iop:Constraint ;
      rdfs:label "Constraint" ;
      iop:constrains ex:Matrix_SysA
    ] ;
    iop:hasMatrix ex:Matrix ;
    iop:hasStatisticalModifier ex:S1 ;
    iop:hasContextObject ex:C1, ex:C2 ;
    iop:hasObjectOfInterest ex:OoI ;
    iop:hasProperty ex:Prop .

ex:Matrix a iop:Entity,
        iop:System ;
    rdfs:label "Matrix" ;
    iop:hasSource ex:Matrix_SysA ;
    iop:hasTarget ex:Matrix_SysB .

ex:OoI a iop:Entity ;
    rdfs:label "OoI" .

ex:Prop a iop:Property ;
    rdfs:label "Prop" .

ex:Matrix_SysA a iop:Entity ;
    rdfs:label "SysA" .

ex:Matrix_SysB a iop:Entity ;
    rdfs:label "SysB" .

ex:C1 a iop:Entity ;
    rdfs:label "C1" .

ex:C2 a iop:Entity ;
    rdfs:label "C2" .

ex:S1 a iop:Entity ;
    rdfs:label "S1" .
