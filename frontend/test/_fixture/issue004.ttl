@prefix iop: <https://w3id.org/iadopt/ont/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/> .

ex:issue004
    a
        iop:Variable ;
    rdfs:label
        "Issue 004" ;
    rdfs:comment
        """if no label is given for systems and they are blank nodes, no title should be shown""" ;
    iop:hasObjectOfInterest
        _:b0 ;
    iop:hasProperty
        ex:Prop .

_:b0
    a
        iop:Entity ,
        iop:AsymmetricSystem ;
    iop:hasNumerator
        ex:PartA ;
    iop:hasDenominator
        ex:PartB .

ex:Prop
    a
        iop:Property ;
    rdfs:label
        "Prop" .

ex:PartA
    a
        iop:Entity ;
    rdfs:label
        "System Part A" .

ex:PartB
    a
        iop:Entity ;
    rdfs:label
        "System Part B" .
